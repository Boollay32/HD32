+/*=============== Modern Navbar & Footer ===================*/
+@import url(https://fonts.googleapis.com/css?family=Roboto:400,500,700,300,100);
+/* Variables */
+/* Mixins */
+.shadow-box {
+  box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.1);
+}
+.fade {
+  transition: all 0.2s ease;
+}
+/* ============= Body Setup ============= */
+body {
+  display: block;
+  /* ✅ Changed from display: none */
+  margin: 0;
+  padding: 0;
+  padding-top: 56px;
+  /* ✅ Space for fixed navbar */
+  padding-bottom: 40px;
+  /* ✅ Space for fixed footer */
+  font-family: Calibri, Arial, sans-serif;
+}
+button {
+  cursor: pointer;
+}
+/* ============= Modern Compact Navbar ============= */
+nav {
+  position: fixed;
+  top: 0;
+  left: 0;
+  right: 0;
+  width: 100%;
+  height: 56px;
+  background: #424141;
+  z-index: 1000;
+  box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.1);
+  display: flex;
+  align-items: center;
+  padding: 0px;
+  gap: 12px;
+  /* Main Menu */
+  /* Logout Section */
+}
+nav #navbar-menu {
+  display: flex;
+  align-items: center;
+  gap: 4px;
+  flex: 1;
+  /* ✅ Take available space */
+  min-width: 0;
+  /* ✅ Allow shrinking */
+  margin: 0;
+  padding: 0;
+  height: 56px;
+  overflow-x: auto;
+  /* ✅ Scroll if needed */
+  overflow-y: hidden;
+  /* Hide scrollbar */
+  -ms-overflow-style: none;
+  scrollbar-width: none;
+}
+nav #navbar-menu::-webkit-scrollbar {
+  display: none;
+}
+nav #navbar-menu .subnav {
+  position: relative;
+  height: 56px;
+  display: flex;
+  align-items: center;
+  padding: 0 8px;
+  /* ✅ Reduced from 12px */
+  flex-shrink: 0;
+  /* ✅ Don't shrink menu items */
+  /* Main menu link */
+  /* Dropdown menu */
+  /* Show dropdown on hover */
+}
+nav #navbar-menu .subnav > a {
+  color: white;
+  font-size: 14px;
+  font-weight: 600;
+  font-family: Calibri;
+  cursor: pointer;
+  padding: 8px 10px;
+  /* ✅ Reduced padding */
+  border-radius: 4px;
+  white-space: nowrap;
+  transition: all 0.2s ease;
+}
+nav #navbar-menu .subnav > a:hover {
+  color: #FFCF7A;
+  background: rgba(255, 255, 255, 0.05);
+}
+nav #navbar-menu .subnav > a.active {
+  color: orange;
+}
+nav #navbar-menu .subnav .subnav-content {
