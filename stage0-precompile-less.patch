+.td-activity-icon.type-12 {
+  background: #FBFAF7;
+  color: #56524B;
+}
+.td-activity-icon.type-13 {
+  background: #fef3c7;
+  color: #A25A06;
+}
+.td-activity-content {
+  display: flex;
+  flex-direction: column;
+  gap: 2px;
+  flex: 1;
+  min-width: 0;
+}
+.td-activity-desc {
+  font-size: 11.5px;
+  color: #1D1C1A;
+  line-height: 1.4;
+  margin: 0;
+}
+.td-activity-desc strong {
+  font-weight: 700;
+  color: #1D1C1A;
+}
+.td-activity-meta {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+}
+.td-activity-actor {
+  font-size: 10.5px;
+  font-weight: 600;
+  color: #56524B;
+}
+.td-activity-time {
+  font-size: 10.5px;
+  color: #6A655C;
+  font-family: "Spline Sans Mono", ui-monospace, monospace;
+}
+.td-activity-time::before {
+  content: '·';
+  margin-right: 8px;
+}
+.td-activity-filter-bar {
+  display: flex;
+  align-items: center;
+  gap: 4px;
+  padding: 8px 16px;
+  border-bottom: 1px solid #D8D3C8;
+  overflow-x: auto;
+  scrollbar-width: none;
+}
+.td-activity-filter-bar::-webkit-scrollbar {
+  display: none;
+}
+.td-activity-filter-btn {
+  padding: 4px 12px;
+  border-radius: 20px;
+  border: 1px solid #D8D3C8;
+  background: none;
+  font-family: "Spline Sans", system-ui, sans-serif;
+  font-size: 10.5px;
+  font-weight: 600;
+  color: #56524B;
+  cursor: pointer;
+  white-space: nowrap;
+  transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
+  flex-shrink: 0;
+}
+.td-activity-filter-btn:hover {
+  background: #FBFAF7;
+  color: #1D1C1A;
+}
+.td-activity-filter-btn.is-active {
+  background: #15695A;
+  border-color: #15695A;
+  color: #fff;
+}
+.td-activity-load-more-wrap {
+  display: flex;
+  justify-content: center;
+  padding: 12px 16px;
+}
+.td-activity-load-more-wrap[hidden] {
+  display: none;
+}
+.td-activity-load-more {
+  padding: 6px 20px;
+  border-radius: 20px;
+  border: 1px solid #D8D3C8;
+  background: none;
+  font-family: "Spline Sans", system-ui, sans-serif;
+  font-size: 11.5px;
+  font-weight: 600;
+  color: #56524B;
+  cursor: pointer;
+  transition: background 0.15s ease, color 0.15s ease;
+}
+.td-activity-load-more:hover {
+  background: #FBFAF7;
+  color: #1D1C1A;
+}
+.td-activity-load-more:disabled {
+  opacity: 0.5;
+  cursor: not-allowed;
+}
+.td-activity-skeleton {
+  display: flex;
+  flex-direction: column;
+  gap: 12px;
+  padding: 16px;
+}
+.td-activity-skeleton[hidden] {
+  display: none;
+}
+.td-activity-skeleton-row {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+}
+.td-activity-skeleton-row .skel-circle {
+  width: 28px;
+  height: 28px;
+  border-radius: 50%;
+  background: #D8D3C8;
+  flex-shrink: 0;
+  animation: shimmer 1.4s infinite;
+}
+.td-activity-skeleton-row .skel-lines {
+  display: flex;
+  flex-direction: column;
+  gap: 6px;
+  flex: 1;
+}
+.td-activity-skeleton-row .skel-lines span {
+  height: 10px;
+  border-radius: 6px;
+  background: #D8D3C8;
+  animation: shimmer 1.4s infinite;
+}
+.td-activity-skeleton-row .skel-lines span:first-child {
+  width: 60%;
+}
+.td-activity-skeleton-row .skel-lines span:last-child {
+  width: 30%;
+}
+.td-form-field {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+.td-form-field label {
+  font-size: 11.5px;
+  font-weight: 700;
+  color: #56524B;
+}
+.td-form-row {
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 12px;
+}
+@media (max-width: 860px) {
+  .td-shell[data-layout="both"] {
+    grid-template-columns: 1fr;
+    grid-template-rows: 1fr 1fr;
+  }
+  .td-shell .td-pane--left {
+    border-right: none;
+    border-bottom: 1px solid #D8D3C8;
+  }
+  .td-shell .td-pane--right {
+    border-top: none;
+  }
+  .td-id-block .td-title {
+    max-width: 50vw;
+  }
+  .td-topbar-meta {
+    display: none;
+  }
+  .td-form-row {
+    grid-template-columns: 1fr;
+  }
+}
+@media (max-width: 560px) {
+  .td-topbar {
+    padding: 0 12px;
+    gap: 8px;
+  }
+  .td-field {
+    grid-template-columns: 1fr;
+    gap: 4px;
+  }
+  .td-field dt {
+    font-size: 10.5px;
+  }
+}
