+}
+nav #navbar-menu .subnav .subnav-content ul li a {
+  display: block;
+  color: white;
+  font-size: 13px;
+  font-weight: 500;
+  font-family: Calibri;
+  padding: 10px 16px;
+  cursor: pointer;
+  transition: all 0.2s ease;
+}
+nav #navbar-menu .subnav .subnav-content ul li a:hover {
+  color: #FFCF7A;
+  background: rgba(255, 255, 255, 0.05);
+}
+nav #navbar-menu .subnav:hover .subnav-content {
