        FilterBox = FilterBoxViewModel.ForRFCs()
    };
}

@section AddJSToBody {
    <script src="~/js/Pages/RFC/RFCPage.js" asp-append-version="true"></script>
}

@await Html.PartialAsync("_ListPage", model)
